{
  "schema_version": 2,
  "codex_usage_url": "https://chatgpt.com/codex/cloud/settings/analytics?locale=pt-BR",
  "network_endpoints": [
    "/backend-api/wham/usage"
  ],
  "profile_dir": "runtime/edge-profile",
  "output_json": "data/codex-usage.json",
  "health_json": "data/collector-health.json",
  "lock_file": "runtime/collector.lock",
  "log_file": "logs/collector.log",
  "debug_dir": "runtime/debug",
  "timezone": "America/Sao_Paulo",
  "browser_channel": "msedge",
  "fallback_to_chromium": true,
  "navigation_timeout_ms": 90000,
  "network_capture_timeout_ms": 10000,
  "dom_wait_timeout_ms": 15000,
  "collector_timeout_seconds": 150,
  "lock_stale_seconds": 300,
  "stale_after_minutes": 45,
  "save_debug_on_success": false,
  "save_debug_on_failure": true,
  "debug_retention_sets": 8,
  "browser_bridge_token_file": "runtime/browser-bridge-token.txt",
  "schedule_interval_minutes": 15,
  "cdp_monitor": {
    "host": "127.0.0.1",
    "port": 9222,
    "profile_dir": "runtime/edge-cdp-profile",
    "refresh_minutes": 5,
    "capture_wait_seconds": 20
  },
  "dashboard": {
    "host": "127.0.0.1",
    "port": 8088,
    "auto_refresh_seconds": 60,
    "allow_remote": false
  }
}
