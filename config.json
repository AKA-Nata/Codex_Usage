{
  "schema_version": 3,
  "codex_usage_url": "https://chatgpt.com/codex/cloud/settings/analytics?locale=pt-BR",
  "output_json": "data/codex-usage.json",
  "health_json": "data/collector-health.json",
  "log_file": "logs/collector.log",
  "timezone": "America/Sao_Paulo",
  "stale_after_minutes": 45,
  "cdp_monitor_timeout_seconds": 45,
  "cdp_monitor": {
    "host": "127.0.0.1",
    "port": 9222,
    "profile_dir": "runtime/edge-cdp-profile",
    "refresh_minutes": 5,
    "capture_wait_seconds": 20
  },
  "dashboard": {
    "host": "127.0.0.1",
    "port": 8088,
    "auto_refresh_seconds": 60,
    "allow_remote": false
  }
}
